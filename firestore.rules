rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Leauges Collection (Multi-Tenant Rooms)
    match /leagues/{leagueId} {
      // Anyone can read a league to join it
      allow read: if true;
      
      // Any authenticated user can create a league
      allow create: if isAuthenticated() && request.resource.data.owner_uid == request.auth.uid;
      
      // Only the league owner can delete or modify the league metadata itself
      allow update, delete: if isAuthenticated() && resource.data.owner_uid == request.auth.uid;

      // ----- SUBCOLLECTIONS WITHIN A LEAGUE -----
      
      // Players in this league
      match /players/{playerId} {
        allow read: if true; // Audience can view players
        // Only the league owner can modify players
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.owner_uid == request.auth.uid;
      }

      // Teams in this league
      match /teams/{teamId} {
        allow read: if true; // Audience can view teams
        // Only the league owner can modify teams
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.owner_uid == request.auth.uid;
      }

      // Auction state in this league
      match /auction/{docId} {
        allow read: if true; // Audience can view live auction status
        // Only the league owner can change auction state
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.owner_uid == request.auth.uid;
      }

      // Bid history in this league
      match /bids/{bidId} {
        allow read: if true; // Audience can view bids
        // Only the league owner can record bids (since placeBid is an admin action)
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.owner_uid == request.auth.uid;
        allow update, delete: if false; // Bids cannot be modified or deleted directly
      }
    }

    // Fallback rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
